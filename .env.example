# Create a free project at https://supabase.com — then run supabase/schema.sql in the SQL Editor.
# For local dev: copy to .env — for GitHub Pages build, add these as repository secrets with the same names (see docs/SUPABASE.md).

PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Used only in GitHub Actions (notify job) — never copy service_role into .env for the Astro app.
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# NOTIFY_FROM=Afsal Thaj <newsletter@yourdomain.com>
