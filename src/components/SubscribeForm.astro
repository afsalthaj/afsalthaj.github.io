---
---

<section class="subscribe" aria-labelledby="subscribe-heading">
	<h2 id="subscribe-heading">Subscribe</h2>
	<p class="subscribe-lead">
		Get updates from this site.
	</p>
	<form class="subscribe-form" data-subscribe-form>
		<label class="sr-only" for="subscribe-email">Email</label>
		<input
			id="subscribe-email"
			name="email"
			type="email"
			required
			placeholder="you@example.com"
			autocomplete="email"
			maxlength="254"
		/>
		<button type="submit">Subscribe</button>
	</form>
	<p class="subscribe-status" data-subscribe-status role="status"></p>
<p class="subscribe-note" data-subscribe-note hidden>
	Configure <code>PUBLIC_SUPABASE_URL</code> and <code>PUBLIC_SUPABASE_ANON_KEY</code> — see
	<code>docs/SUPABASE.md</code>.
</p>
</section>

<script>
	import { getEngagementConfig, insertSubscriber } from '../lib/engagementApi';

	function init() {
		const form = document.querySelector<HTMLFormElement>('[data-subscribe-form]');
		const statusEl = document.querySelector<HTMLElement>('[data-subscribe-status]');
		const noteEl = document.querySelector<HTMLElement>('[data-subscribe-note]');
		if (!form || !statusEl) return;

		// Always prevent native submit — without this, a missing build-time env would GET-reload
		// the page (jump to top) and never call Supabase.
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const config = getEngagementConfig();
			if (!config) {
				if (noteEl) noteEl.hidden = false;
				statusEl.style.color = 'var(--magenta)';
				statusEl.textContent =
					'Subscription is not configured for this build. Add PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY to the GitHub Actions / build env, then redeploy. See docs/SUPABASE.md.';
				return;
			}
			if (noteEl) noteEl.hidden = true;
			const fd = new FormData(form);
			const email = String(fd.get('email') || '');
			if (!email) return;
			statusEl.style.color = 'var(--text-muted)';
			statusEl.textContent = 'Sending…';
			const r = await insertSubscriber(config.url, config.key, email);
			if (r === 'ok') {
				statusEl.style.color = 'var(--cyan)';
				statusEl.textContent = "You're subscribed — thank you.";
				form.reset();
			} else if (r === 'duplicate') {
				statusEl.style.color = 'var(--text-muted)';
				statusEl.textContent = "You're already on the list.";
			} else {
				statusEl.style.color = 'var(--magenta)';
				statusEl.textContent =
					'Could not subscribe (check Network tab: 401 = wrong key, CORS = add your site URL in Supabase).';
			}
		});

		// Show hint on load if env missing (static deploys often forget secrets)
		const config = getEngagementConfig();
		if (!config) {
			if (noteEl) noteEl.hidden = false;
			statusEl.textContent = '';
		} else if (noteEl) {
			noteEl.hidden = true;
		}
	}
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init, { once: true });
	} else {
		init();
	}
</script>

<style>
	.subscribe {
		margin-top: 0;
		padding-top: 0;
		border-top: none;
		text-align: left;
		width: 100%;
		min-width: 0;
	}
	.subscribe h2 {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--cyan);
		margin: 0 0 0.5rem;
	}
	.subscribe-lead {
		color: var(--text-muted);
		font-size: 0.8rem;
		margin: 0 0 1rem;
		line-height: 1.5;
		max-width: 42rem;
	}
	.subscribe-lead strong {
		color: var(--magenta);
	}
	.subscribe-form {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0.75rem;
		width: 100%;
		max-width: min(22rem, 100%);
		min-width: 0;
	}
	.subscribe-form input[type='email'] {
		width: 100%;
		max-width: 100%;
		min-width: 0;
		padding: 0.55rem 0.65rem;
		font-size: 16px;
		background: var(--bg);
		color: var(--text);
		border: 1px solid var(--border);
		border-radius: 4px;
		font-family: inherit;
	}
	.subscribe-check {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		font-size: 0.78rem;
		color: var(--text-muted);
		text-align: left;
		width: 100%;
		cursor: pointer;
	}
	.subscribe-check input {
		margin-top: 0.2rem;
		accent-color: var(--magenta);
	}
	.subscribe-form button {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.55rem 1.25rem;
		background: transparent;
		color: var(--text-muted);
		border: 1px solid var(--border);
		border-radius: 4px;
		cursor: pointer;
		transition: color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.subscribe-form button:hover {
		color: var(--cyan);
		border-color: var(--cyan);
		box-shadow: var(--glow-cyan);
	}
	.subscribe-status {
		min-height: 1.25em;
		font-size: 0.78rem;
		margin: 0.75rem 0 0;
		text-align: left;
		max-width: min(22rem, 100%);
	}
	.subscribe-note {
		font-size: 0.72rem;
		color: var(--text-muted);
		margin: 0.5rem 0 0;
		max-width: min(28rem, 100%);
		line-height: 1.4;
	}
	.subscribe-note code {
		font-size: 0.85em;
	}
</style>
