---
interface Props {
	/** Content collection `id` (used as the like key) */
	postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="post-engagement" data-post-slug={postSlug}>
	<div class="post-engagement__row">
		<button type="button" class="post-engagement__like" data-like-btn>
			<span class="post-engagement__heart" aria-hidden="true">♥</span>
			Like
		</button>
		<span class="post-engagement__count" data-like-count aria-live="polite">…</span>
		<span class="post-engagement__hint" data-like-hint></span>
	</div>
	<p class="post-engagement__disabled" data-like-disabled hidden>
		Likes are not configured — set <code>PUBLIC_SUPABASE_URL</code> and
		<code>PUBLIC_SUPABASE_ANON_KEY</code> and run <code>supabase/schema.sql</code>.
	</p>
</div>

<script>
	import {
		fetchPostLikeCount,
		getEngagementConfig,
		incrementPostLike,
	} from '../lib/engagementApi';

	const LIKE_KEY = (slug: string) => `ribbb_liked_${slug}`;

	type RibbbWin = Window & { __ribbbLikeClickBound?: boolean };

	/**
	 * One listener for the whole tab — avoids duplicate handlers when init runs again (e.g. bfcache).
	 * Must use `document`, not `document.body`: Astro ClientRouter replaces the entire `<body>` on each
	 * in-site navigation, so a body listener is orphaned and `__ribbbLikeClickBound` would block rebinding.
	 */
	function ensureDelegatedLikeClick() {
		const w = window as RibbbWin;
		if (w.__ribbbLikeClickBound) return;
		w.__ribbbLikeClickBound = true;
		document.addEventListener(
			'click',
			async (e) => {
				const t = e.target as HTMLElement | null;
				if (!t) return;
				const btn = t.closest<HTMLButtonElement>('[data-like-btn]');
				if (!btn || btn.disabled) return;
				const root = btn.closest<HTMLElement>('.post-engagement');
				if (!root) return;
				const slug = (root.dataset.postSlug || '').trim();
				if (!slug) return;
				const config = getEngagementConfig();
				if (!config) return;
				const hintEl = root.querySelector<HTMLElement>('[data-like-hint]');
				const countEl = root.querySelector<HTMLElement>('[data-like-count]');
				if (!countEl) return;

				const ok = await incrementPostLike(config.url, config.key, slug);
				if (!ok) {
					if (hintEl) hintEl.textContent = 'Could not record like. Try again later.';
					return;
				}
				const n = await fetchPostLikeCount(config.url, config.key, slug);
				countEl.textContent = String(n);
				try {
					localStorage.setItem(LIKE_KEY(slug), '1');
				} catch {
					/* private mode / blocked */
				}
				btn.disabled = true;
				if (hintEl) hintEl.textContent = 'Thanks!';
			},
			true
		);
	}

	function syncBlock(root: HTMLElement) {
		const slug = (root.dataset.postSlug || '').trim();
		const btn = root.querySelector<HTMLButtonElement>('[data-like-btn]');
		const countEl = root.querySelector<HTMLElement>('[data-like-count]');
		const hintEl = root.querySelector<HTMLElement>('[data-like-hint]');
		const disabledEl = root.querySelector<HTMLParagraphElement>('[data-like-disabled]');
		if (!slug || !btn || !countEl) return;

		const config = getEngagementConfig();
		if (!config) {
			if (disabledEl) disabledEl.hidden = false;
			countEl.textContent = '—';
			btn.disabled = true;
			return;
		}
		if (disabledEl) disabledEl.hidden = true;

		countEl.textContent = '…';
		void (async () => {
			const n = await fetchPostLikeCount(config.url, config.key, slug);
			countEl.textContent = String(n);
		})();

		btn.disabled = false;
		if (hintEl) hintEl.textContent = '';
		if (typeof localStorage !== 'undefined' && localStorage.getItem(LIKE_KEY(slug))) {
			btn.disabled = true;
			if (hintEl) hintEl.textContent = 'Thanks!';
		}
	}

	function init() {
		ensureDelegatedLikeClick();
		document.querySelectorAll<HTMLElement>('.post-engagement').forEach((root) => syncBlock(root));
	}

	// ClientRouter (View Transitions): in-site navigations swap the DOM without reload, so
	// DOMContentLoaded does not run again — likes would stay at SSR "…" / wrong state until a full refresh.
	document.addEventListener('astro:page-load', init);

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init, { once: true });
	} else {
		init();
	}

	// Back/forward cache (Safari / Chrome): page can be shown again without re-running the module.
	window.addEventListener('pageshow', (ev) => {
		if (ev.persisted) init();
	});
</script>

<style>
	.post-engagement {
		margin-top: 2.5rem;
		padding-top: 1.75rem;
		border-top: 1px solid var(--border);
	}
	.post-engagement__row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
	}
	.post-engagement__like {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.5rem 1rem;
		background: transparent;
		color: var(--magenta);
		border: 1px solid var(--magenta);
		border-radius: 6px;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		transition: color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.post-engagement__like:hover:not(:disabled) {
		color: var(--cyan);
		border-color: var(--cyan);
		box-shadow: var(--glow-cyan);
	}
	.post-engagement__like:disabled {
		opacity: 0.6;
		cursor: default;
	}
	.post-engagement__heart {
		font-size: 0.9rem;
		line-height: 1;
	}
	.post-engagement__count {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--cyan);
		min-width: 1.5ch;
	}
	.post-engagement__hint {
		font-size: 0.78rem;
		color: var(--text-muted);
		flex: 1 1 100%;
	}
	.post-engagement__disabled {
		margin: 0.75rem 0 0;
		font-size: 0.75rem;
		color: var(--text-muted);
		line-height: 1.5;
	}
	.post-engagement__disabled code {
		font-size: 0.85em;
	}
</style>
