---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL, SOCIAL_LINKS } from '../consts';
import profileImage from '../assets/profile.jpeg';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 5);

const talks = [
	{
		title: 'Rib — A Language That Could Improve the Ecosystem of WASM',
		event: 'LambdaConf 2025',
		url: 'https://www.youtube.com/watch?v=vgrZxN0t-N0',
	},
	{
		title: 'Timeline Analytics With Golem Backend',
		event: 'LambdaConf 2024',
		url: 'https://www.youtube.com/watch?v=9WjUBOfgriY',
	},
	{
		title: 'The Ubiquity of FP Concepts in Latest Tech',
		event: 'Functional Scala 2023',
		url: 'https://www.youtube.com/watch?v=5SUvqLgJKRk',
	},
	{
		title: 'ZIO Constraintless',
		event: 'ZIO World 2023',
		url: 'https://www.youtube.com/watch?v=jtxO7LJXW0Q',
	},
];

/**
 * Home OSS grid: order by GitHub interest (roughly: stars) — Golem, zio-config, then
 * zio-constraintless, rib, durable-timeline-analytics. Two-column layout puts zio-config beside Golem.
 */
const ossRecent = [
	{
		orgRepo: 'golemcloud/golem',
		name: 'Golem',
		blurb: 'Durable, WASM-based distributed runtime',
		url: 'https://github.com/golemcloud/golem',
	},
	{
		orgRepo: 'zio/zio-config',
		name: 'zio-config',
		blurb: 'Composable config in ZIO apps',
		url: 'https://github.com/zio/zio-config',
	},
	{
		orgRepo: 'zio/zio-constraintless',
		name: 'zio-constraintless',
		blurb: 'DSLs and typeclass instances at interpretation',
		url: 'https://github.com/zio/zio-constraintless',
	},
	{
		orgRepo: 'golemcloud/rib',
		name: 'Rib',
		blurb: 'Type-safe language for WebAssembly',
		url: 'https://github.com/golemcloud/rib',
	},
	{
		orgRepo: 'afsalthaj/durable-timeline-analytics',
		name: 'durable-timeline-analytics',
		blurb: 'Durable data engineering on Golem',
		url: 'https://github.com/afsalthaj/durable-timeline-analytics',
	},
] as const;

const personJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Afsal Thaj',
	url: SITE_URL,
	jobTitle: 'Senior Software Engineer',
	worksFor: {
		'@type': 'Organization',
		name: 'Golem Cloud',
		url: 'https://golem.cloud',
	},
	sameAs: [SOCIAL_LINKS.github, SOCIAL_LINKS.linkedin, SOCIAL_LINKS.x],
	knowsAbout: [
		'Distributed Systems',
		'Durable Execution',
		'WebAssembly',
		'Functional Programming',
		'Rust',
	],
};

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: SITE_URL,
	description: SITE_DESCRIPTION,
	author: {
		'@type': 'Person',
		name: 'Afsal Thaj',
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(personJsonLd)}></script>
		<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-text">
					<h1>
						<a href="/about" class="hero-title-link">Afsal Thaj</a>
					</h1>
					<p class="tagline">
						<span class="tagline-accent">Distrubted Systems</span>
						<span class="tagline-sep">·</span>
						<span class="tagline-accent">Durable Agent Runtime</span>
						<span class="tagline-sep">·</span>
						<span class="tagline-accent">Functional Programming</span>
					</p>
				</div>
				<Image src={profileImage} alt="Afsal Thaj" class="profile-photo" width={140} height={140} />
			</section>

			<section class="recent-posts">
				<h2>Recent Posts</h2>
				<ul>
					{recentPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="view-all text-link-draw">View all posts →</a>
			</section>

			<section class="talks">
				<h2>Recent Talks</h2>
				<div class="talks-grid">
					{talks.map((talk) => (
						<a href={talk.url} target="_blank" rel="noopener noreferrer" class="talk-card">
							<span class="talk-event">{talk.event}</span>
							<span class="talk-title">{talk.title}</span>
							<span class="watch-link">▶ Watch</span>
						</a>
					))}
				</div>
				<a href="/talks" class="view-all text-link-draw">View all talks →</a>
			</section>

			<section class="oss-recent" aria-label="Open source contributions">
				<h2>Recent OSS contributions</h2>
				<div class="oss-recent-grid">
					{ossRecent.map((repo) => (
						<a href={repo.url} target="_blank" rel="noopener noreferrer" class="oss-recent-card">
							<span class="oss-recent-org">{repo.orgRepo}</span>
							<span class="oss-recent-name">{repo.name}</span>
							<span class="oss-recent-blurb">{repo.blurb}</span>
							<span class="oss-recent-cta">↗ GitHub</span>
						</a>
					))}
				</div>
				<a
					href="https://github.com/afsalthaj"
					target="_blank"
					rel="noopener noreferrer"
					class="view-all text-link-draw">View all my work →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		position: relative;
		padding: 3em 0 2em;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2em;
		overflow: visible;
	}
	/* Very soft lift — text glow stays the hero; background stays nearly flat */
	.hero::before {
		content: '';
		position: absolute;
		inset: -15% -8% -8%;
		pointer-events: none;
		background: radial-gradient(
			ellipse 90% 80% at 48% 28%,
			rgba(0, 255, 249, 0.03),
			transparent 70%
		);
		z-index: 0;
	}
	.hero > * {
		position: relative;
		z-index: 1;
	}
	.hero-text {
		flex: 1;
	}
	.hero h1 {
		font-size: 2.8em;
		margin-bottom: 0.3em;
		text-shadow: var(--glow-cyan-hero);
	}
	/* Keep hero cyan — global `a` would otherwise be magenta */
	.hero h1 .hero-title-link {
		color: var(--cyan);
		text-decoration: none;
		text-shadow: var(--glow-cyan-hero);
		cursor: pointer;
		transition: filter 0.2s ease;
	}
	.hero h1 .hero-title-link:hover,
	.hero h1 .hero-title-link:focus-visible {
		color: var(--cyan);
		text-shadow: var(--glow-cyan-hero);
		text-decoration: none;
		filter: brightness(1.1);
	}
	.tagline {
		color: var(--text-muted);
		font-size: 1em;
		margin: 0;
		line-height: 1.6;
	}
	.tagline-accent {
		color: var(--magenta);
	}
	.tagline-sep {
		margin: 0 0.25em;
		opacity: 0.5;
	}
	.profile-photo {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		border: 2px solid var(--cyan);
		box-shadow:
			0 0 0 1px rgba(0, 255, 249, 0.35),
			var(--glow-cyan);
		object-fit: cover;
		flex-shrink: 0;
	}

	@media (prefers-reduced-motion: no-preference) {
		.hero-text h1 {
			animation: hero-in 0.65s ease backwards;
		}
		.hero-text .tagline {
			animation: hero-in 0.65s ease 0.1s backwards;
		}
		.profile-photo {
			animation:
				hero-in 0.65s ease 0.2s backwards,
				photo-ring 3.2s ease-in-out 0.85s infinite;
		}
	}

	@keyframes hero-in {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes photo-ring {
		0%,
		100% {
			box-shadow:
				0 0 0 1px rgba(0, 255, 249, 0.35),
				0 0 6px rgba(0, 255, 249, 0.34),
				0 0 14px rgba(0, 255, 249, 0.18),
				0 0 26px rgba(0, 255, 249, 0.08);
		}
		50% {
			box-shadow:
				0 0 0 2px rgba(0, 255, 249, 0.45),
				0 0 10px rgba(0, 255, 249, 0.42),
				0 0 22px rgba(0, 255, 249, 0.22),
				0 0 34px rgba(0, 255, 249, 0.1);
		}
	}

	/* Recent Posts */
	.recent-posts {
		margin-bottom: 3em;
	}
	.recent-posts h2,
	.talks h2,
	.oss-recent h2 {
		font-size: 1.2em;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1em;
	}
	.recent-posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.recent-posts li {
		border-bottom: 1px solid var(--border);
	}
	.recent-posts li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.8em 0;
		color: var(--text);
		text-decoration: none;
		transition: all 0.2s ease;
		gap: 1em;
	}
	.recent-posts li a:hover {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}
	.post-title {
		flex: 1;
	}
	.post-date {
		color: var(--text-date);
		font-size: 0.85em;
		white-space: nowrap;
		flex-shrink: 0;
		padding-right: 0.1em;
	}

	/* Talks */
	.talks {
		margin-bottom: 3em;
	}
	.talks-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
	}
	.talk-card {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		padding: 1.2em;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: 6px;
		text-decoration: none;
		color: var(--text);
		transition: all 0.25s ease;
	}
	.talk-card:hover {
		border-color: var(--cyan);
		box-shadow: var(--glow-cyan);
		transform: translateY(-2px);
	}
	.talk-event {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.65em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--magenta);
	}
	.talk-title {
		font-size: 0.95em;
		line-height: 1.4;
		flex: 1;
	}
	.talk-card:hover .talk-title {
		color: var(--cyan);
	}
	.watch-link {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.7em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--magenta);
	}
	.talk-card:hover .watch-link {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}

	/* Recent OSS */
	.oss-recent {
		margin-bottom: 2em;
	}
	.oss-recent-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
	}
	.oss-recent-card {
		display: flex;
		flex-direction: column;
		gap: 0.35em;
		padding: 1.2em;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: 6px;
		text-decoration: none;
		color: var(--text);
		transition: all 0.25s ease;
	}
	.oss-recent-card:hover {
		border-color: var(--cyan);
		box-shadow: var(--glow-cyan);
		transform: translateY(-2px);
	}
	.oss-recent-org {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.68em;
		letter-spacing: 0.02em;
		color: var(--magenta);
	}
	.oss-recent-name {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.95em;
		color: var(--text);
		line-height: 1.35;
	}
	.oss-recent-card:hover .oss-recent-name {
		color: var(--cyan);
	}
	.oss-recent-blurb {
		font-size: 0.82em;
		line-height: 1.45;
		color: var(--text-muted);
		flex: 1;
	}
	.oss-recent-cta {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.7em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--magenta);
	}
	.oss-recent-card:hover .oss-recent-cta {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}

	/* Shared */
	.view-all {
		display: inline-block;
		margin-top: 1.5em;
		color: var(--magenta);
		text-decoration: none;
		font-family: 'Orbitron', sans-serif;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.view-all:hover {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}
	@media (max-width: 720px) {
		.hero {
			flex-direction: column-reverse;
			text-align: center;
		}
		.hero h1 {
			font-size: 2em;
		}
		.recent-posts li a {
			flex-direction: column;
			gap: 0.2em;
		}
		.talks-grid,
		.oss-recent-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
