---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import profileImage from '../assets/profile.jpeg';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 5);

const talks = [
	{
		title: 'Rib — A Language That Could Improve the Ecosystem of WASM',
		event: 'LambdaConf 2025',
		url: 'https://www.youtube.com/watch?v=vgrZxN0t-N0',
	},
	{
		title: 'Timeline Analytics With Golem Backend',
		event: 'LambdaConf 2024',
		url: 'https://www.youtube.com/watch?v=9WjUBOfgriY',
	},
	{
		title: 'The Ubiquity of FP Concepts in Latest Tech',
		event: 'Functional Scala 2023',
		url: 'https://www.youtube.com/watch?v=5SUvqLgJKRk',
	},
	{
		title: 'ZIO Constraintless',
		event: 'ZIO World 2023',
		url: 'https://www.youtube.com/watch?v=jtxO7LJXW0Q',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-text">
					<h1>Afsal Thaj</h1>
					<p class="tagline">Distributed systems · Functional programming · Software engineering</p>
				</div>
				<Image src={profileImage} alt="Afsal Thaj" class="profile-photo" width={140} height={140} />
			</section>

			<section class="recent-posts">
				<h2>Recent Posts</h2>
				<ul>
					{recentPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="view-all">View all posts →</a>
			</section>

			<section class="talks">
				<h2>Talks</h2>
				<div class="talks-grid">
					{talks.map((talk) => (
						<a href={talk.url} target="_blank" rel="noopener noreferrer" class="talk-card">
							<span class="talk-event">{talk.event}</span>
							<span class="talk-title">{talk.title}</span>
							<span class="watch-link">▶ Watch</span>
						</a>
					))}
				</div>
				<a href="/talks" class="view-all">View all talks →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 3em 0 2em;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2em;
	}
	.hero-text {
		flex: 1;
	}
	.hero h1 {
		font-size: 2.8em;
		margin-bottom: 0.3em;
		text-shadow: var(--glow-cyan);
	}
	.tagline {
		color: var(--text-muted);
		font-size: 1em;
		margin: 0;
	}
	.profile-photo {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		border: 2px solid var(--cyan);
		box-shadow: var(--glow-cyan);
		object-fit: cover;
		flex-shrink: 0;
	}

	/* Recent Posts */
	.recent-posts {
		margin-bottom: 3em;
	}
	.recent-posts h2, .talks h2 {
		font-size: 1.2em;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1em;
	}
	.recent-posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.recent-posts li {
		border-bottom: 1px solid var(--border);
	}
	.recent-posts li a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.8em 0;
		color: var(--text);
		text-decoration: none;
		transition: all 0.2s ease;
		gap: 1em;
	}
	.recent-posts li a:hover {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}
	.post-title {
		flex: 1;
	}
	.post-date {
		color: var(--text-muted);
		font-size: 0.85em;
		white-space: nowrap;
	}

	/* Talks */
	.talks {
		margin-bottom: 2em;
	}
	.talks-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
	}
	.talk-card {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		padding: 1.2em;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: 6px;
		text-decoration: none;
		color: var(--text);
		transition: all 0.25s ease;
	}
	.talk-card:hover {
		border-color: var(--cyan);
		box-shadow: var(--glow-cyan);
		transform: translateY(-2px);
	}
	.talk-event {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.65em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--magenta);
	}
	.talk-title {
		font-size: 0.95em;
		line-height: 1.4;
		flex: 1;
	}
	.talk-card:hover .talk-title {
		color: var(--cyan);
	}
	.watch-link {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.7em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--magenta);
	}
	.talk-card:hover .watch-link {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}

	/* Shared */
	.view-all {
		display: inline-block;
		margin-top: 1.5em;
		color: var(--magenta);
		text-decoration: none;
		font-family: 'Orbitron', sans-serif;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.view-all:hover {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}
	@media (max-width: 720px) {
		.hero {
			flex-direction: column-reverse;
			text-align: center;
		}
		.hero h1 {
			font-size: 2em;
		}
		.recent-posts li a {
			flex-direction: column;
			gap: 0.2em;
		}
		.talks-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
