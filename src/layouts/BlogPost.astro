---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<link rel="stylesheet" href="https://unpkg.com/applause-button/dist/applause-button.css" />
		<script src="https://unpkg.com/applause-button/dist/applause-button.js" defer></script>
		<style>
			.read-progress {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: 3px;
				z-index: 200;
				background: rgba(10, 10, 15, 0.92);
				pointer-events: none;
			}
			.read-progress__bar {
				display: block;
				height: 100%;
				width: 0%;
				background: linear-gradient(90deg, var(--magenta), var(--cyan));
			}
			@media (prefers-reduced-motion: no-preference) {
				.read-progress__bar {
					transition: width 0.12s linear;
				}
			}

			.prose {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				min-width: 0;
			}

			.title {
				margin-bottom: 1.5em;
				padding: 1em 0;
				border-bottom: 1px solid var(--border);
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				text-shadow: var(--glow-cyan-hero);
				line-height: 1.15;
			}
			@media (max-width: 720px) {
				.title h1 {
					font-size: 1.55em;
				}
			}
			.date {
				color: var(--text-date);
				font-size: 0.9em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 1em;
				color: var(--text-muted);
				font-family: 'Orbitron', sans-serif;
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
			}
			.back-link:hover {
				color: var(--cyan);
				text-shadow: var(--glow-cyan);
			}
			.article-body {
				min-width: 0;
				max-width: 100%;
				overflow-wrap: break-word;
			}
			.article-body :global(pre) {
				max-width: 100%;
			}
			.article-body :global(img),
			.article-body :global(video) {
				max-width: 100%;
				height: auto;
			}
			.like-section {
				margin-top: 3em;
				padding-top: 2em;
				border-top: 1px solid var(--border);
				display: flex;
				align-items: center;
				gap: 1em;
				flex-wrap: wrap;
			}
			.like-section applause-button {
				width: 50px;
				height: 50px;
				--applause-button-color: var(--magenta);
			}
			.like-label {
				color: var(--text-muted);
				font-size: 0.85em;
				font-family: 'Orbitron', sans-serif;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
		</style>
	</head>

	<body>
		<div class="read-progress" aria-hidden="true">
			<span class="read-progress__bar"></span>
		</div>
		<Header />
		<main>
			<article class="prose">
				<a href="/blog" class="back-link">← Back to posts</a>
				<div class="title">
					<h1>{title}</h1>
					<div class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<div class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
				</div>
				<div class="article-body">
					<slot />
				</div>
				<div class="like-section">
					<applause-button multiclap="true" />
					<span class="like-label">Like this post</span>
				</div>
			</article>
		</main>
		<Footer />
		<script is:inline>
			(function () {
				var body = document.querySelector('.article-body');
				var bar = document.querySelector('.read-progress__bar');
				if (!body || !bar) return;

				function updateProgress() {
					var scrollTop = window.scrollY || document.documentElement.scrollTop;
					var rect = body.getBoundingClientRect();
					var start = scrollTop + rect.top;
					var height = body.offsetHeight;
					var winH = window.innerHeight;
					var end = start + height - winH;
					var p = (scrollTop - start) / (end - start);
					if (p < 0) p = 0;
					if (p > 1) p = 1;
					if (!isFinite(p)) p = 0;
					bar.style.width = (p * 100).toFixed(2) + '%';
				}

				window.addEventListener('scroll', updateProgress, { passive: true });
				window.addEventListener('resize', updateProgress);
				updateProgress();
			})();
		</script>
	</body>
</html>
