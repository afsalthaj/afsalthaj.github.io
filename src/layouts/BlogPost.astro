---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<link rel="stylesheet" href="https://unpkg.com/applause-button/dist/applause-button.css" />
		<script src="https://unpkg.com/applause-button/dist/applause-button.js" defer></script>
		<style>
			.read-progress {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: 3px;
				z-index: 200;
				background: rgba(10, 10, 15, 0.92);
				pointer-events: none;
			}
			.read-progress__bar {
				display: block;
				height: 100%;
				width: 0%;
				background: linear-gradient(90deg, var(--magenta), var(--cyan));
			}
			@media (prefers-reduced-motion: no-preference) {
				.read-progress__bar {
					transition: width 0.12s linear;
				}
			}

			.prose {
				width: 780px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.prose-layout {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5em;
				align-items: start;
			}
			@media (min-width: 1100px) {
				.prose-layout {
					grid-template-columns: minmax(0, 11.5em) minmax(0, 1fr);
					gap: 2rem;
				}
			}
			.toc-wrap {
				display: none;
			}
			@media (min-width: 1100px) {
				.toc-wrap {
					display: block;
					position: sticky;
					top: 4.5rem;
					padding-top: 0.25em;
				}
				.toc-wrap.toc-wrap--empty {
					display: none;
				}
			}
			.toc-label {
				font-family: 'Orbitron', sans-serif;
				font-size: 0.65em;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--text-muted);
				margin: 0 0 0.75em;
			}
			.toc :global(ul) {
				list-style: none;
				padding: 0;
				margin: 0;
				font-size: 0.72em;
				line-height: 1.45;
			}
			.toc :global(li) {
				margin: 0 0 0.45em;
			}
			.toc :global(a) {
				color: var(--text-muted);
				text-decoration: none;
				border-left: 2px solid transparent;
				padding-left: 0.5em;
				margin-left: -2px;
				display: block;
				transition:
					color 0.2s ease,
					border-color 0.2s ease;
			}
			.toc :global(a:hover) {
				color: var(--cyan);
			}
			.toc :global(li.toc__h3 a) {
				padding-left: 1em;
				font-size: 0.95em;
			}

			.title {
				margin-bottom: 1.5em;
				padding: 1em 0;
				border-bottom: 1px solid var(--border);
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				text-shadow: var(--glow-cyan-hero);
			}
			.date {
				color: var(--text-muted);
				font-size: 0.9em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 1em;
				color: var(--text-muted);
				font-family: 'Orbitron', sans-serif;
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
			}
			.back-link:hover {
				color: var(--cyan);
				text-shadow: var(--glow-cyan);
			}
			.article-body :global(h2),
			.article-body :global(h3) {
				scroll-margin-top: 5rem;
			}
			.like-section {
				margin-top: 3em;
				padding-top: 2em;
				border-top: 1px solid var(--border);
				display: flex;
				align-items: center;
				gap: 1em;
			}
			.like-section applause-button {
				width: 50px;
				height: 50px;
				--applause-button-color: var(--magenta);
			}
			.like-label {
				color: var(--text-muted);
				font-size: 0.85em;
				font-family: 'Orbitron', sans-serif;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
		</style>
	</head>

	<body>
		<div class="read-progress" aria-hidden="true">
			<span class="read-progress__bar"></span>
		</div>
		<Header />
		<main>
			<article>
				<div class="prose">
					<a href="/blog" class="back-link">← Back to posts</a>
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
					</div>
					<div class="prose-layout">
						<aside class="toc-wrap" data-toc-root>
							<p class="toc-label">On this page</p>
							<nav class="toc" id="article-toc" aria-label="On this page"></nav>
						</aside>
						<div class="prose-column">
							<div class="article-body">
								<slot />
							</div>
							<div class="like-section">
								<applause-button multiclap="true" />
								<span class="like-label">Like this post</span>
							</div>
						</div>
					</div>
				</div>
			</article>
		</main>
		<Footer />
		<script is:inline>
			(function () {
				function slugify(text) {
					return text
						.trim()
						.toLowerCase()
						.replace(/[^\w\s-]/g, '')
						.replace(/\s+/g, '-')
						.replace(/-+/g, '-')
						.slice(0, 64);
				}

				var body = document.querySelector('.article-body');
				var toc = document.getElementById('article-toc');
				var tocWrap = document.querySelector('[data-toc-root]');
				var bar = document.querySelector('.read-progress__bar');
				if (!body) return;

				var headings = body.querySelectorAll('h2, h3');
				if (toc && tocWrap && headings.length >= 2) {
					var ul = document.createElement('ul');
					headings.forEach(function (h, i) {
						var id = h.id;
						if (!id) {
							id = slugify(h.textContent || '') || 'section-' + i;
							var unique = id;
							var n = 0;
							while (document.getElementById(unique)) unique = id + '-' + ++n;
							h.id = unique;
						}
						var li = document.createElement('li');
						if (h.tagName === 'H3') li.className = 'toc__h3';
						var a = document.createElement('a');
						a.href = '#' + h.id;
						a.textContent = h.textContent || '';
						li.appendChild(a);
						ul.appendChild(li);
					});
					toc.appendChild(ul);
				} else if (tocWrap) {
					tocWrap.classList.add('toc-wrap--empty');
				}

				function updateProgress() {
					if (!bar) return;
					var el = body;
					var rect = el.getBoundingClientRect();
					var scrollTop = window.scrollY || document.documentElement.scrollTop;
					var start = scrollTop + rect.top;
					var height = el.offsetHeight;
					var winH = window.innerHeight;
					var end = start + height - winH;
					var p = (scrollTop - start) / (end - start);
					if (p < 0) p = 0;
					if (p > 1) p = 1;
					if (!isFinite(p)) p = 0;
					bar.style.width = (p * 100).toFixed(2) + '%';
				}

				window.addEventListener('scroll', updateProgress, { passive: true });
				window.addEventListener('resize', updateProgress);
				updateProgress();
			})();
		</script>
	</body>
</html>
