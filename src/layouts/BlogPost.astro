---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<link rel="stylesheet" href="https://unpkg.com/applause-button/dist/applause-button.css" />
		<script src="https://unpkg.com/applause-button/dist/applause-button.js" defer></script>
		<style>
			.prose {
				width: 780px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.title {
				margin-bottom: 1.5em;
				padding: 1em 0;
				border-bottom: 1px solid var(--border);
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				text-shadow: var(--glow-cyan);
			}
			.date {
				color: var(--text-muted);
				font-size: 0.9em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 1em;
				color: var(--text-muted);
				font-family: 'Orbitron', sans-serif;
				font-size: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
			}
			.back-link:hover {
				color: var(--cyan);
				text-shadow: var(--glow-cyan);
			}
			.like-section {
				margin-top: 3em;
				padding-top: 2em;
				border-top: 1px solid var(--border);
				display: flex;
				align-items: center;
				gap: 1em;
			}
			.like-section applause-button {
				width: 50px;
				height: 50px;
				--applause-button-color: var(--magenta);
			}
			.like-label {
				color: var(--text-muted);
				font-size: 0.85em;
				font-family: 'Orbitron', sans-serif;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<a href="/blog" class="back-link">← Back to posts</a>
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
					</div>
					<slot />
					<div class="like-section">
						<applause-button multiclap="true" />
						<span class="like-label">Like this post</span>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
